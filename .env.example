# Kopieer dit bestand naar ".env.local" en vul je eigen LiveKit Cloud-gegevens in.
# Zie README.md voor een stap-voor-stap uitleg om een gratis LiveKit Cloud-project aan te maken.

# De WebSocket-URL van je LiveKit-project, bijv. wss://jouw-project.livekit.cloud
# Deze wordt zowel server- als clientseitig gebruikt (client verbindt hier rechtstreeks mee),
# daarom NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# API Key en Secret uit je LiveKit Cloud dashboard (Settings > Keys).
# Deze blijven server-side (geen NEXT_PUBLIC_ prefix) en worden alleen gebruikt
# om join-tokens te genereren in src/app/api/join/route.ts.
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=your-secret-here

# Geheime sleutel voor de admin-pagina (/admin), waar je uitnodigingslinks
# aanmaakt en beheert. Verzin zelf een lange, willekeurige waarde en deel
# deze met niemand. Zonder deze variabele is /admin niet bruikbaar.
ADMIN_KEY=change-me-to-a-long-random-secret

# Naam van de (ene, vaste) LiveKit-kamer waar alle uitnodigingen naartoe leiden.
ROOM_NAME=studio

# Hoe lang een uitnodigingslink geldig blijft voordat hij vanzelf verloopt (in uren).
INVITE_TTL_HOURS=24

# Upstash Redis (REST-verbinding) voor de opslag van uitnodigingstokens.
# Nodig omdat de app op Vercel draait (serverless functies hebben geen
# eigen, blijvende schijf) — Redis met een TTL per token vervangt het lokale
# bestand. Gratis tier op https://upstash.com is ruim voldoende.
#
# Zo vind je beide waarden:
# 1. Maak een gratis account op https://console.upstash.com
# 2. Klik op "Create Database" (kies een regio dicht bij je Vercel-deployment,
#    bijv. Frankfurt/eu-west als je in Europa zit).
# 3. Open de nieuwe database en ga naar het tabblad "REST API".
# 4. Daar staan "UPSTASH_REDIS_REST_URL" en "UPSTASH_REDIS_REST_TOKEN" kant-en-
#    klaar om te kopiëren (er is vaak ook een ".env"-knop die beide regels
#    in één keer voor je genereert).
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
